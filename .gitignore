# .gitignore - Ignore files not intended for version control
# ---------------------------------------------------------
# This project uses environment files and runtime artefacts that should not be
# committed to git. The rules below focus on:
#   - Sensitive configuration (.env).
#   - Logs generated by Asterisk or auxiliary tools.
#   - Runtime state directories.
#   - Local overrides used only on specific machines.

# Environment files (sensitive)
.env
.env.*

# Rendered Asterisk configs (can contain secrets)
asterisk/pjsip.conf

# Logs
*.log
logs/
log/
/var/log/asterisk

# Asterisk runtime directories (if ever bind-mounted to the host)
/var/spool/asterisk
/var/run/asterisk
/tmp/asterisk*

# Docker-related artefacts
*.pid

# Node / realtime-bridge
realtime-bridge/node_modules/
realtime-bridge/npm-debug.log*
realtime-bridge/fly.toml

# macOS cruft
.DS_Store

# Diagrams (Draw.io)
*.drawio.bkp
*.drawio.dtmp
docs/diagrams/.$*.drawio.bkp
docs/diagrams/.$*.drawio.dtmp

# Pi-specific override files
# --------------------------
# If you add host-specific override compose files or configuration for the Pi,
# you can ignore them here. These entries are placeholders to avoid accidental
# commits of per-device tweaks.
compose/docker-compose.pi.override.yml
ansible/local-overrides.yml

# Generated reports (from ODIN threat-intel workflows)
docs/threat-landscape-*.html

# Cline / AI assistant state
.clinerules
.tmp/
