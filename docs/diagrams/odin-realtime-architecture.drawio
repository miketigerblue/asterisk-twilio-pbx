  <diagram id="2eYU_goQM_ZF48kTf61G" name="Audio buffering + pacing + backpressure (OpenAI -&gt; Twilio)">
    <mxGraphModel dx="2565" dy="1535" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
